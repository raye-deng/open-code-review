{
  "name": "@opencodereview/core",
  "version": "2.1.2",
  "description": "Core detection engine for AI-generated code — hallucinated packages, phantom dependencies, stale APIs, security anti-patterns. Structural, embedding, and LLM scanning.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scanner": {
      "import": "./dist/scanner/index.js",
      "types": "./dist/scanner/index.d.ts"
    },
    "./detectors/v4": {
      "import": "./dist/detectors/v4/index.js",
      "types": "./dist/detectors/v4/index.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/v4-config.js",
      "types": "./dist/config/v4-config.d.ts"
    },
    "./reporter": {
      "import": "./dist/reporter/index.js",
      "types": "./dist/reporter/index.d.ts"
    },
    "./reporter/v4-terminal": {
      "import": "./dist/reporter/v4-terminal.js",
      "types": "./dist/reporter/v4-terminal.d.ts"
    },
    "./scorer": {
      "import": "./dist/scorer/scoring-engine.js",
      "types": "./dist/scorer/scoring-engine.d.ts"
    },
    "./scorer/v4-adapter": {
      "import": "./dist/scorer/v4-adapter.js",
      "types": "./dist/scorer/v4-adapter.d.ts"
    },
    "./ai/v4": {
      "import": "./dist/ai/v4/index.js",
      "types": "./dist/ai/v4/index.d.ts"
    },
    "./ir": {
      "import": "./dist/ir/index.js",
      "types": "./dist/ir/index.d.ts"
    },
    "./parser": {
      "import": "./dist/parser/index.js",
      "types": "./dist/parser/index.d.ts"
    },
    "./registry": {
      "import": "./dist/registry/index.js",
      "types": "./dist/registry/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/"
  },
  "keywords": [
    "ai",
    "ai-code-review",
    "ai-generated-code",
    "ast",
    "ast-analysis",
    "ci-cd",
    "code-analysis",
    "code-quality",
    "code-safety",
    "code-scanner",
    "github-actions",
    "gitlab-ci",
    "go",
    "hallucination-detection",
    "java",
    "javascript",
    "kotlin",
    "npm",
    "phantom-package",
    "phantom-packages",
    "python",
    "quality-gate",
    "sarif",
    "security",
    "static-analysis",
    "supply-chain",
    "typescript"
  ],
  "author": "Raye Deng <fengsen.deng@gmail.com>",
  "license": "MIT",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/raye-deng"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/raye-deng/open-code-review"
  },
  "homepage": "https://codes.evallab.ai",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "acorn": "^8.11.0",
    "acorn-walk": "^8.3.0",
    "glob": "^10.3.0",
    "oxc-parser": "^0.117.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "yaml": "^2.8.2"
  }
}
