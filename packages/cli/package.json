{
  "name": "@opencodereview/cli",
  "version": "2.1.1",
  "description": "Detect AI-hallucinated packages, phantom dependencies, and stale APIs in your codebase. Open-source CI/CD quality gate with local Ollama support — zero API cost.",
  "type": "module",
  "bin": {
    "opencodereview": "./dist/index.js",
    "ocr": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "eslint src/"
  },
  "keywords": [
    "ai",
    "code-quality",
    "code-review",
    "ci-cd",
    "ci",
    "cd",
    "static-analysis",
    "linter",
    "npm-audit",
    "security",
    "supply-chain",
    "dependency-check",
    "ollama",
    "local-ai",
    "sarif",
    "github-actions",
    "gitlab-ci",
    "phantom-packages",
    "phantom-dependencies",
    "hallucination-detection",
    "ai-hallucination",
    "code-scanner",
    "ai-generated-code",
    "developer-tools",
    "quality-gate",
    "pre-commit",
    "code-verification",
    "ai-coding",
    "copilot",
    "cursor",
    "ai-assistant",
    "code-safety",
    "vulnerability-detection",
    "package-validation",
    "api-deprecation",
    "stale-api"
  ],
  "author": "Raye Deng <fengsen.deng@gmail.com>",
  "license": "BUSL-1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/raye-deng/open-code-review"
  },
  "homepage": "https://codes.evallab.ai",
  "bugs": {
    "url": "https://github.com/raye-deng/open-code-review/issues"
  },
  "dependencies": {
    "@opencodereview/core": "^2.1.1",
    "glob": "^10.3.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
